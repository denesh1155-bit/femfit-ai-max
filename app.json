{
  "expo": {
    "name": "FemFit AI Max",
    "slug": "femfit-ai-max",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1025"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.femfit.ai.max"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/icon.png",
        "backgroundColor": "#1A1025"
      },
      "package": "com.femfit.ai.max"
    },
    "web": {
      "favicon": "./src/assets/icon.png"
    },
    "plugins": [
      "expo-localization",
      "expo-local-authentication",
      "expo-av",
      "expo-camera",
      "expo-file-system",
      "expo-haptics"
    ]
  }
}
